# SQLite runtime store
SQL_STORE_ENABLED=true
SQL_STORE_DRIVER=sqlite
SQLITE_DB_PATH=server/data/freguesia.sqlite
SQL_STORE_REQUIRE=true
SQL_STORE_DUAL_WRITE_JSON=false
SQL_STORE_CACHE_TTL_MS=1200

# WhatsApp runtime split
WHATSAPP_HTTP_ENABLED=true
WHATSAPP_SCHEDULERS_ENABLED=false
WHATSAPP_STORE_CACHE_TTL_MS=3000
WHATSAPP_MAX_MESSAGES_PER_CONVERSATION=200
WHATSAPP_MESSAGE_LIST_CACHE_MAX_ENTRIES=500
WHATSAPP_MESSAGE_RESPONSE_CACHE_MAX_ENTRIES=300
WHATSAPP_MEDIA_PROXY_CACHE_MAX_BYTES=10485760

# Worker service overrides these in systemd:
# FREGUESIA_RUNTIME_ROLE=worker
# WHATSAPP_HTTP_ENABLED=false
# WHATSAPP_SCHEDULERS_ENABLED=true

# API ports
WHATSAPP_SERVER_PORT=5250
CHECKOUT_SERVER_PORT=5251
PANEL_AGENT_PORT=5252
PORT=5253

# Internal service URLs
LOCAL_WHATSAPP_API_BASE_URL=http://127.0.0.1:5250
WHATSAPP_API_BASE_URL=http://127.0.0.1:5250
LOCAL_CHECKOUT_API_BASE_URL=http://127.0.0.1:5251
CHECKOUT_API_BASE_URL=http://127.0.0.1:5251
LOCAL_CHECKOUT_TOKEN_API_BASE_URL=http://127.0.0.1:5250
CHECKOUT_TOKEN_API_BASE_URL=http://127.0.0.1:5250
CHECKOUT_WHATSAPP_API_URL=http://127.0.0.1:5250

# AppBarber customer sync
APPBARBER_USER=
APPBARBER_PASSWORD=
APPBARBER_CHROME_PATH=/usr/bin/chromium
APPBARBER_SYNC_PAGE_SIZE=1000
APPBARBER_SYNC_MAX_PAGES=0
APPBARBER_FETCH_AGENDAMENTOS=true
APPBARBER_AGENDAMENTOS_CONCURRENCY=2
APPBARBER_AGENDAMENTOS_DATA_INI=
APPBARBER_AGENDAMENTOS_DATA_FIM=
APPBARBER_DAILY_SYNC_ENABLED=true
APPBARBER_DAILY_SYNC_TIME=00:00

# Local Whisper audio transcription
WHISPER_ENABLED=true
WHISPER_MODEL=base
WHISPER_LANGUAGE=pt
WHISPER_PYTHON_BIN=/opt/freguesia-whisper-venv/bin/python
WHISPER_TMP_DIR=server/data/whisper-tmp
WHISPER_MAX_AUDIO_MB=25
WHISPER_TIMEOUT_MS=180000
